# Copy this file to .env (or export these directly in your shell) before
# running OdorSig. Nothing in this repository ships with real credentials or
# machine-specific paths — see code/Automation_code/config.py.

# REQUIRED. NCBI Entrez requires a real contact email for API requests.
ODORSIG_ENTREZ_EMAIL=you@example.com

# Optional overrides — leave unset to use the defaults described below.

# Executable names/paths for AutoDock Vina, Open Babel, and PyMOL.
# Defaults assume these are already on your PATH (see README installation
# steps). Set an explicit path only if the executable isn't on PATH.
# ODORSIG_VINA_EXE=vina
# ODORSIG_OBABEL_PATH=obabel
# ODORSIG_PYMOL_PATH=pymol

# ChromeDriver. Leave unset to let Selenium Manager (Selenium >= 4.6)
# auto-download and cache the correct driver for your installed Chrome.
# Only set this if you need to pin a specific chromedriver binary.
# ODORSIG_CHROMEDRIVER=/path/to/chromedriver

# Where OdorSig stores intermediate and output files. Defaults to a "runs/"
# folder created next to the repository root.
# ODORSIG_BASE_DIR=/path/to/Automated-Molecular-Docking

# Only used by dataset/code.py when regenerating the large-scale dataset:
# an Excel file with "Receptor" and "Ligand" columns listing the pairs to run.
# ODORSIG_PAIR_LIST_XLSX=/path/to/pair_list.xlsx
